<Window
    x:Class="Portal.Host.UpdateToastWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="340"
    Height="132"
    ShowInTaskbar="False"
    ShowActivated="False"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True">
    <Border
        Padding="14"
        Background="#141f33"
        BorderBrush="#3a5d95"
        BorderThickness="1"
        CornerRadius="14">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Ellipse
                        Width="9"
                        Height="9"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Fill="#4cd964" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#f4f8ff"
                        Text="{Binding UpdateToastTitle}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Width="24"
                    Height="24"
                    Background="#243755"
                    BorderBrush="#315080"
                    BorderThickness="1"
                    Command="{Binding DismissUpdateToastCommand}"
                    Content="×"
                    Cursor="Hand"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="#dce8ff" />
            </Grid>

            <TextBlock
                Margin="0,8,0,0"
                FontSize="12"
                Foreground="#b7c9ee"
                Text="{Binding UpdateToastMessage}"
                TextWrapping="Wrap" />

            <StackPanel
                Margin="0,10,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
                <Button
                    Padding="12,6"
                    Background="#273b5f"
                    BorderBrush="#3b5f94"
                    BorderThickness="1"
                    Command="{Binding OpenUpdateWizardFromToastCommand}"
                    Content="Open"
                    Cursor="Hand"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#eaf1ff" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
